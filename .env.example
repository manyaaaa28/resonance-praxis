# Environment Configuration for RESONANCE
# Copy this file to .env and fill in your API keys

# Grok AI (Primary) - Get from https://console.x.ai
XAI_API_KEY=your_xai_api_key_here

# Gemini AI (Backup) - Get from https://aistudio.google.com/app/apikey  
GEMINI_API_KEY=your_gemini_api_key_here

# Server Configuration
PORT=3000

# AI Provider: 'grok' or 'gemini'
AI_PROVIDER=gemini
